{
  "name": "promotion-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:demo": "APP_MODE=demo PORT=3001 tsx src/index.ts",
    "start:real-test": "APP_MODE=real_test PORT=3002 tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/db-init.ts",
    "db:embedded": "tsx scripts/start-embedded-postgres.ts",
    "redis:embedded": "tsx scripts/start-embedded-redis.ts",
    "billing:mock": "tsx scripts/start-billing-adapter-mock.ts",
    "alerts:mock": "tsx scripts/start-alert-mock.ts",
    "worker:settlement": "tsx scripts/start-settlement-worker.ts",
    "worker:settlement:real-test": "APP_MODE=real_test SETTLEMENT_WORKER_METRICS_PORT=9465 tsx scripts/start-settlement-worker.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.8.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "embedded-postgres": "18.3.0-beta.16",
    "redis-memory-server": "^0.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
